<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net9.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <RootNamespace>Photon.App</RootNamespace>
    <AssemblyName>Photon</AssemblyName>
    <ApplicationHighDpiMode>PerMonitorV2</ApplicationHighDpiMode>
    <Version>1.0.1</Version>
    <!-- Allows compiling (not running) the Windows target on macOS/Linux dev machines. -->
    <EnableWindowsTargeting>true</EnableWindowsTargeting>
    <!-- .NET 9 dark mode API (Application.SetColorMode) is marked experimental. -->
    <NoWarn>$(NoWarn);WFO5001</NoWarn>
    <ApplicationIcon Condition="Exists('Assets\photon.ico')">Assets\photon.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="System.Management" Version="9.0.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Photon.Core\Photon.Core.csproj" />
  </ItemGroup>

</Project>
